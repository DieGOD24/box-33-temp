# ── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# ── Auth ─────────────────────────────────────────────────────────────────────
# Required. Min 32 chars. Production refuses to boot with the dev fallback.
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Seeded owner login for the dashboard (created on first boot if no user exists)
ADMIN_EMAIL=coach@box33.fit
ADMIN_PASSWORD=

# ── PostgreSQL ───────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5433
DB_USER=box33
DB_PASSWORD=box33
DB_NAME=box33
# true only in dev/CI — schema is owned by migrations everywhere else
DB_SYNCHRONIZE=

# ── Wompi payments ───────────────────────────────────────────────────────────
# Sandbox keys start with pub_test_/prv_test_; production with pub_prod_/prv_prod_.
# Without them the store checkout is disabled and buyers fall back to WhatsApp.
WOMPI_PUBLIC_KEY=
WOMPI_PRIVATE_KEY=
WOMPI_INTEGRITY_SECRET=
WOMPI_EVENTS_SECRET=

# ── Web revalidation hook (API → Next.js on-demand ISR) ──────────────────────
WEB_URL=http://localhost:3000
REVALIDATION_SECRET=

# ── Uploads ──────────────────────────────────────────────────────────────────
# Directory where dashboard image uploads are stored (mounted volume in Docker)
UPLOADS_DIR=./data/uploads
