{
  "name": "@box33/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "rm -f tsconfig.build.tsbuildinfo tsconfig.tsbuildinfo && nest build",
    "dev": "rm -f tsconfig.build.tsbuildinfo tsconfig.tsbuildinfo && nest start --watch",
    "start": "node dist/main",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate -d src/database/data-source.ts",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d src/database/data-source.ts",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -d src/database/data-source.ts",
    "migrate:prod": "node dist/database/migrate.js"
  },
  "dependencies": {
    "@box33/types": "workspace:*",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/serve-static": "^4.0.2",
    "@nestjs/swagger": "^8.1.0",
    "@nestjs/throttler": "^6.3.0",
    "@nestjs/typeorm": "^10.0.2",
    "argon2": "^0.44.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "helmet": "^8.2.0",
    "multer": "^2.0.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.30"
  },
  "devDependencies": {
    "@box33/typescript-config": "workspace:*",
    "@nestjs/cli": "^10.4.9",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.20.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.11.10",
    "@typescript-eslint/eslint-plugin": "^8.19.0",
    "@typescript-eslint/parser": "^8.19.0",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.17.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  }
}
